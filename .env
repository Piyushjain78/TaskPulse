# Copy to .env and adjust. Used by docker-compose and apps.

# Database (defaults match docker-compose postgres service)
POSTGRES_USER=taskpulse
POSTGRES_PASSWORD=taskpulse
POSTGRES_DB=taskpulse
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://taskpulse:taskpulse@localhost:5432/taskpulse?schema=public

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Frontend (browser uses host machine to reach backend)
VITE_API_URL=http://localhost:4000
VITE_WS_URL=http://localhost:4000
FRONTEND_PORT=5173

# CORS (comma-separated origins for browser clients)
CORS_ORIGIN=http://localhost:5173

# WhatsApp — Msg91 (https://docs.msg91.com/p/whatsapp/)
MSG91_AUTH_KEY=
MSG91_WHATSAPP_INTEGRATED_NUMBER=
MSG91_TEMPLATE_NAMESPACE=
MSG91_TEMPLATE_TASK_ASSIGNED=
MSG91_TEMPLATE_TASK_COMPLETED=
WHATSAPP_PROVIDER=msg91

# Optional: Gupshup sandbox (set WHATSAPP_PROVIDER=gupshup to use)
GUPSHUP_USER_ID=
GUPSHUP_PASSWORD=
GUPSHUP_APP_NAME=
